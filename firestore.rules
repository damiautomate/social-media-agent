rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // A user can read/write only their own user document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /brandConfig/{configDoc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Drafts: read-your-own-rows. All writes server-only via Admin SDK.
    match /drafts/{draftId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Ideas: same pattern.
    match /ideas/{ideaId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Bootstrap proposals are a singleton per user keyed by userId.
    // User reads their own; only the Cloud Function writes/updates.
    match /bootstrap_proposals/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // Pending jobs, analytics, and research signals are server-only end to end.
    match /pending_jobs/{jobId} {
      allow read, write: if false;
    }

    match /analytics/{analyticsId} {
      allow read, write: if false;
    }

    match /research_signals/{signalId} {
      allow read, write: if false;
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
