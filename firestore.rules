rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // A user can read/write only their own user document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Brand config lives as a subcollection under the user.
      match /brandConfig/{configDoc} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Drafts: read-your-own-rows for live dashboard updates.
    // All writes are server-only via Admin SDK.
    match /drafts/{draftId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Ideas: same pattern as drafts.
    match /ideas/{ideaId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Pending jobs and analytics are server-only end to end.
    match /pending_jobs/{jobId} {
      allow read, write: if false;
    }

    match /analytics/{analyticsId} {
      allow read, write: if false;
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
